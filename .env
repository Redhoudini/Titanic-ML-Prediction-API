FLASK_ENV=development
FLASK_APP=manage.py
SECRET_KEY=dev-secret-change-me

POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

DATABASE_URL=postgresql+psycopg2://appuser:apppassword@db:5432/appdb

#ANSVAR:
#Dine “hemmelige”/konfig værdier: DB-navn, user, password, og DATABASE_URL.
#Bruges både af Postgres (til at oprette) og Flask (til at forbinde).